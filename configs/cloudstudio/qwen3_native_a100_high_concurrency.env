# A100-oriented native flash-attn high-concurrency throughput run.
# Switch the CloudStudio GPU to A100 before running this config.
EXPERIMENT_NAME=qwen3_native_a100_high_concurrency
OUTPUT_ROOT=reports/cloudstudio
INSTALL_PROFILE=native
INSTALL_FLASH_ATTN=auto
SETUP_PYTHON=python
RUNNER_PYTHON=python
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121
MAX_JOBS=4

HF_MODEL_ID=Qwen/Qwen3-0.6B
HF_LOCAL_DIR=.cache/models/Qwen3-0.6B
MODEL=.cache/models/Qwen3-0.6B
MODEL_BACKEND=native
ATTENTION_BACKEND=flash_attn
OP_BACKEND=torch

HOST=127.0.0.1
PORT=8000
GPU_MEMORY_UTILIZATION=0.92
TENSOR_PARALLEL_SIZE=1
DISTRIBUTED_BACKEND=nccl
CUDA_DEVICE_OFFSET=0
ENFORCE_EAGER=true

MAX_NUM_BATCHED_TOKENS=32768
MAX_NUM_SEQS=512
MAX_MODEL_LEN=4096
MAX_PREFILL_CHUNK_TOKENS=2048
MIN_PREFILL_CHUNK_TOKENS=32
SCHEDULER_FAIRNESS=decode_first
KVCACHE_WATERMARK_BLOCKS=32

PREFIX_CACHE_MIN_TOKENS=256
CACHE_NAMESPACE=qwen3-a100-high-concurrency
REQUEST_NAMESPACE=qwen3-native

PROMPT="Explain continuous batching and paged KV cache in one sentence."
MAX_TOKENS=128
BENCHMARK_REQUESTS=512
BENCHMARK_CONCURRENCY=64
CACHE_PROBE_REPETITIONS=384
CACHE_PROBE_MAX_TOKENS=16

REQUEST_TIMEOUT_S=300
QUEUE_TIMEOUT_S=30
SERVER_READY_TIMEOUT_S=480
HTTP_TIMEOUT_S=300
COMMAND_TIMEOUT_S=2400
