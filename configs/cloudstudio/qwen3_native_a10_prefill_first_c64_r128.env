# A10 high-concurrency optimized probe based on the 2026-06-17 bottleneck report.
# Uses prefill_first, CUDA graph decode, and moderate SSE chunk coalescing.
EXPERIMENT_NAME=qwen3_native_a10_prefill_first_c64_r128
OUTPUT_ROOT=reports/cloudstudio
INSTALL_PROFILE=native
INSTALL_FLASH_ATTN=auto
SETUP_PYTHON=python
RUNNER_PYTHON=python
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121
MAX_JOBS=2

HF_MODEL_ID=Qwen/Qwen3-0.6B
HF_LOCAL_DIR=.cache/models/Qwen3-0.6B
MODEL=.cache/models/Qwen3-0.6B
MODEL_BACKEND=native
ATTENTION_BACKEND=flash_attn
OP_BACKEND=torch

HOST=127.0.0.1
PORT=8000
GPU_MEMORY_UTILIZATION=0.90
TENSOR_PARALLEL_SIZE=1
DISTRIBUTED_BACKEND=nccl
CUDA_DEVICE_OFFSET=0
ENFORCE_EAGER=false

MAX_NUM_BATCHED_TOKENS=16384
MAX_NUM_SEQS=256
MAX_MODEL_LEN=4096
MAX_PREFILL_CHUNK_TOKENS=2048
MIN_PREFILL_CHUNK_TOKENS=16
SCHEDULER_FAIRNESS=prefill_first
KVCACHE_WATERMARK_BLOCKS=16

PREFIX_CACHE_MIN_TOKENS=256
MAX_CACHED_BLOCKS=0
MAX_CACHED_BLOCKS_PER_NAMESPACE=0
CACHE_NAMESPACE=qwen3-a10-prefill-first-c64-r128
REQUEST_NAMESPACE=qwen3-native

STREAM_INTERVAL=4
PROMPT="Explain continuous batching and paged KV cache in one sentence."
MAX_TOKENS=128
BENCHMARK_REQUESTS=128
BENCHMARK_CONCURRENCY=64
CACHE_PROBE_REPETITIONS=384
CACHE_PROBE_MAX_TOKENS=8

REQUEST_TIMEOUT_S=300
QUEUE_TIMEOUT_S=30
SERVER_READY_TIMEOUT_S=360
HTTP_TIMEOUT_S=300
COMMAND_TIMEOUT_S=2400
