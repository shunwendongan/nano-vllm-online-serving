# Native nano-vLLM experiment using the optional CUDA decode attention backend.
# Use only after the flash-attn baseline works on the same GPU/runtime.
EXPERIMENT_NAME=qwen3_native_cuda_ext_decode
OUTPUT_ROOT=reports/colab
INSTALL_PROFILE=native
INSTALL_FLASH_ATTN=auto

HF_MODEL_ID=Qwen/Qwen3-0.6B
HF_LOCAL_DIR=/content/models/Qwen3-0.6B
MODEL=/content/models/Qwen3-0.6B
MODEL_BACKEND=native
ATTENTION_BACKEND=cuda_ext
OP_BACKEND=torch

HOST=127.0.0.1
PORT=8000
GPU_MEMORY_UTILIZATION=0.90
TENSOR_PARALLEL_SIZE=1
DISTRIBUTED_BACKEND=nccl
CUDA_DEVICE_OFFSET=0
ENFORCE_EAGER=true

MAX_NUM_BATCHED_TOKENS=8192
MAX_NUM_SEQS=128
MAX_MODEL_LEN=4096
MAX_PREFILL_CHUNK_TOKENS=1024
MIN_PREFILL_CHUNK_TOKENS=16
SCHEDULER_FAIRNESS=alternate
KVCACHE_WATERMARK_BLOCKS=8

PREFIX_CACHE_MIN_TOKENS=256
CACHE_NAMESPACE=qwen3-cuda-ext
REQUEST_NAMESPACE=qwen3-native

PROMPT="Explain continuous batching and paged KV cache in one sentence."
MAX_TOKENS=64
BENCHMARK_REQUESTS=32
BENCHMARK_CONCURRENCY=4
CACHE_PROBE_REPETITIONS=384
CACHE_PROBE_MAX_TOKENS=8

REQUEST_TIMEOUT_S=180
QUEUE_TIMEOUT_S=20
SERVER_READY_TIMEOUT_S=300
HTTP_TIMEOUT_S=180
COMMAND_TIMEOUT_S=1200
