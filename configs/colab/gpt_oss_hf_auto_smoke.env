# Colab smoke test for OpenAI gpt-oss through the Transformers compatibility path.
# This does not measure native nano-vLLM continuous batching or paged-KV speed.
EXPERIMENT_NAME=gpt_oss_hf_auto_smoke
OUTPUT_ROOT=reports/colab
INSTALL_PROFILE=hf_auto
INSTALL_FLASH_ATTN=0

MODEL=openai/gpt-oss-20b
MODEL_BACKEND=hf_auto
ATTENTION_BACKEND=flash_attn
OP_BACKEND=torch

HOST=127.0.0.1
PORT=8000
GPU_MEMORY_UTILIZATION=0.90
TENSOR_PARALLEL_SIZE=1
DISTRIBUTED_BACKEND=nccl
CUDA_DEVICE_OFFSET=0

PROMPT="Explain continuous batching and paged KV cache in one sentence."
MAX_TOKENS=64
BENCHMARK_REQUESTS=32
BENCHMARK_CONCURRENCY=4
SKIP_CACHE_PROBE=true
CACHE_NAMESPACE=gpt-oss-hf-auto
REQUEST_NAMESPACE=gpt-oss-smoke

REQUEST_TIMEOUT_S=300
QUEUE_TIMEOUT_S=30
SERVER_READY_TIMEOUT_S=900
HTTP_TIMEOUT_S=300
COMMAND_TIMEOUT_S=1800
